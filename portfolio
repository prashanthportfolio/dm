  <script>
    /* ── HERO: typewriter ── */
    const NAME = 'PRASHANTH';
    const el   = document.getElementById('nameTyped');
    const cur  = document.getElementById('nameCursor');
    let i = 0;
    function type(){
      if(i < NAME.length){ el.textContent += NAME[i++]; setTimeout(type, 95); }
      else { setTimeout(()=>{ cur.style.display='none'; }, 1200); }
    }
    setTimeout(type, 900);

    /* ── ABOUT: tilt + cursor + float ── */
    const section   = document.getElementById('about');
    const tilt      = document.getElementById('imgTilt');
    const shimmer   = document.getElementById('shimmer');
    const expBadge  = document.getElementById('expBadge');
    const toolBadge = document.getElementById('toolBadge');
    const bgGlow    = document.getElementById('bgGlow');
    const dot       = document.getElementById('cursorDot');
    const ring      = document.getElementById('cursorRing');

    let floatTick = 0;
    let currentRX = 0, currentRY = 0, targetRX = 0, targetRY = 0;
    let dotX = 0, dotY = 0, ringX = 0, ringY = 0;
    let mousePageX = 0, mousePageY = 0;

    function lerp(a,b,t){ return a+(b-a)*t; }

    function loop(){
      floatTick += 0.016;
      const fy = Math.sin(floatTick) * 7;
      const fr = Math.sin(floatTick * 0.65) * 1.4;
      currentRX = lerp(currentRX, targetRX, 0.1);
      currentRY = lerp(currentRY, targetRY, 0.1);
      tilt.style.transform = `translateY(${fy}px) rotateZ(${fr}deg) rotateX(${currentRX}deg) rotateY(${currentRY}deg)`;
      expBadge.style.transform  = `translateY(${-fy*0.5}px) rotateZ(${-fr*0.4}deg)`;
      toolBadge.style.transform = `translateY(${fy*0.4}px) rotateZ(${fr*0.3}deg)`;
      dotX  = lerp(dotX,  mousePageX, 0.18);
      dotY  = lerp(dotY,  mousePageY, 0.18);
      ringX = lerp(ringX, mousePageX, 0.1);
      ringY = lerp(ringY, mousePageY, 0.1);
      dot.style.left  = dotX  + 'px';
      dot.style.top   = dotY  + 'px';
      ring.style.left = ringX + 'px';
      ring.style.top  = ringY + 'px';
      requestAnimationFrame(loop);
    }
    loop();

    document.addEventListener('mousemove', e => {
      mousePageX = e.clientX;
      mousePageY = e.clientY;
      const sr = section.getBoundingClientRect();
      bgGlow.style.left = (e.clientX - sr.left) + 'px';
      bgGlow.style.top  = (e.clientY - sr.top)  + 'px';
    });

    tilt.addEventListener('mouseenter', () => {
      dot.style.opacity = '1'; ring.style.opacity = '1';
      ring.style.width = '52px'; ring.style.height = '52px';
    });
    tilt.addEventListener('mouseleave', () => {
      dot.style.opacity = '0'; ring.style.opacity = '0';
      ring.style.width = '36px'; ring.style.height = '36px';
      targetRX = 0; targetRY = 0;
    });
    tilt.addEventListener('mousemove', e => {
      const rect = tilt.getBoundingClientRect();
      const cx = rect.left + rect.width  / 2;
      const cy = rect.top  + rect.height / 2;
      const maxD = Math.max(rect.width, rect.height) / 2;
      targetRY = ((e.clientX - cx) / maxD) * 20;
      targetRX = -((e.clientY - cy) / maxD) * 15;
      const px = ((e.clientX - rect.left) / rect.width)  * 100;
      const py = ((e.clientY - rect.top)  / rect.height) * 100;
      shimmer.style.background = `radial-gradient(circle at ${px}% ${py}%, rgba(255,255,255,0.1) 0%, transparent 55%)`;
    });

    setTimeout(()=>{
      document.getElementById('imgCol').classList.add('visible');
      document.getElementById('textCol').classList.add('visible');
    }, 200);
  </script>
