<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Prashanth – Video Editor & Visual Designer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600&family=Syne:wght@700;800&display=swap" rel="stylesheet"/>
  <style>

    /* ─── RESET ─── */
    *{margin:0;padding:0;box-sizing:border-box;}
    body{background:#0a0a0a;font-family:'Inter',sans-serif;overflow-x:hidden;}

    /* ══════════════════════════════════════
       HERO SECTION
    ══════════════════════════════════════ */
    .hero{
      width:100%;min-height:520px;
      background:#0a0a0a;
      background-image:
        radial-gradient(ellipse at 20% 50%, rgba(120,40,200,0.5) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 50%, rgba(30,60,255,0.45) 0%, transparent 55%),
        radial-gradient(ellipse at 50% 100%, rgba(80,0,160,0.3) 0%, transparent 50%);
      position:relative;overflow:hidden;
      font-family:'Inter',sans-serif;
      display:flex;flex-direction:column;
    }

    .nav{
      position:relative;z-index:20;
      display:flex;justify-content:center;gap:40px;
      padding:22px 0 0;
    }
    .nav a{
      font-size:10px;font-weight:600;letter-spacing:0.2em;
      text-transform:uppercase;color:#fff;text-decoration:none;
      transition:color 0.2s;cursor:pointer;
    }
    .nav a:hover{color:#f6ee7d;}

    .hero-body{
      flex:1;position:relative;
      display:flex;align-items:center;justify-content:center;
      min-height:460px;
    }

    .big-text{
      position:absolute;top:40%;left:50%;
      transform:translate(-50%,-50%);
      z-index:2;text-align:center;width:100%;
      padding:0 16px;pointer-events:none;line-height:0.88;
    }
    .hi-line{
      font-family:'Anton',sans-serif;
      font-size:clamp(100px,14vw,130px);
      color:#ffef75;letter-spacing:0.02em;display:block;
      opacity:0;transform:translateY(-20px);
      animation:dropIn 0.6s cubic-bezier(.22,1,.36,1) 0.2s forwards;
    }
    .name-line{
      font-family:'Anton',sans-serif;
      font-size:clamp(200px,14vw,130px);
      letter-spacing:0.02em;display:block;
      opacity:0;transform:translateY(20px);
      animation:riseIn 0.6s cubic-bezier(.22,1,.36,1) 0.5s forwards;
      background:linear-gradient(90deg,#ffffff 0%,#c0c0c0 100%);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .name-typed{display:inline;}
    .cursor-blink{
      display:inline-block;width:6px;height:0.82em;
      background:#fff;vertical-align:middle;margin-left:4px;
      animation:blink 0.75s step-end infinite;
      -webkit-text-fill-color:#fff;
    }

    .portrait{
      position:relative;z-index:10;
      display:flex;align-items:flex-end;justify-content:center;
      height:100%;width:100%;pointer-events:none;
    }
    .portrait img{
      height:400px;max-height:80%;width:auto;object-fit:contain;display:block;
      opacity:0;transform:scale(0.94) translateY(10px);
      animation:imgIn 1s cubic-bezier(.22,1,.36,1) 2s forwards;
      filter:drop-shadow(0 0 60px rgba(255,255,255,0.06));
    }

    .hero-left-text{
      position:absolute;left:28px;bottom:44px;z-index:15;
      max-width:190px;opacity:0;
      animation:fadeUp 0.6s ease 1.3s forwards;
    }
    .hero-left-text p{
      font-size:11px;font-weight:400;line-height:1.65;
      color:#fff;text-transform:uppercase;letter-spacing:0.06em;
    }

    .contact-btn{
      position:absolute;right:28px;bottom:44px;z-index:15;
      opacity:0;animation:fadeUp 0.6s ease 1.5s forwards;
    }
    .contact-btn button{
      background:linear-gradient(135deg,#7c3aed,#4f46e5,#0ea5e9);
      color:#fff;border:none;padding:12px 24px;
      font-size:11px;font-weight:700;letter-spacing:0.14em;
      text-transform:uppercase;border-radius:40px;cursor:pointer;
      transition:transform 0.2s,opacity 0.2s;font-family:'Inter',sans-serif;
    }
    .contact-btn button:hover{transform:scale(1.05);opacity:0.9;}

    .bottom-line{
      position:absolute;bottom:0;left:0;right:0;height:1px;
      background:linear-gradient(90deg,transparent,rgba(255,255,255,0.08),transparent);
      z-index:5;
    }
    .grain{
      position:absolute;inset:0;z-index:1;opacity:0.03;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.75' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size:150px;pointer-events:none;
    }

    @keyframes dropIn{to{opacity:1;transform:translateY(0);}}
    @keyframes riseIn{to{opacity:1;transform:translateY(0);}}
    @keyframes blink{0%,100%{opacity:1;}50%{opacity:0;}}
    @keyframes imgIn{to{opacity:1;transform:scale(1) translateY(0);}}
    @keyframes fadeUp{from{opacity:0;transform:translateY(14px);}to{opacity:1;transform:translateY(0);}}

    /* ══════════════════════════════════════
       ABOUT SECTION
    ══════════════════════════════════════ */
    .cursor-dot{
      position:fixed;width:10px;height:10px;border-radius:50%;
      background:linear-gradient(135deg,#7c3aed,#0ea5e9);
      pointer-events:none;z-index:9999;
      transform:translate(-50%,-50%);
      transition:transform 0.08s ease,opacity 0.2s;opacity:0;
    }
    .cursor-ring{
      position:fixed;width:36px;height:36px;border-radius:50%;
      border:1.5px solid rgba(124,58,237,0.6);
      pointer-events:none;z-index:9998;
      transform:translate(-50%,-50%);
      transition:transform 0.18s ease,opacity 0.2s,width 0.2s,height 0.2s;opacity:0;
    }

    .about{
      width:100%;background:#111111;
      padding:90px 60px 110px;
      font-family:'Inter',sans-serif;
      overflow:hidden;position:relative;
    }
    .bg-glow{
      position:absolute;width:500px;height:500px;border-radius:50%;
      background:radial-gradient(circle,rgba(124,58,237,0.08) 0%,transparent 70%);
      pointer-events:none;transform:translate(-50%,-50%);z-index:0;
      transition:left 0.1s ease,top 0.1s ease;
    }
    .section-tag{
      position:relative;z-index:2;
      display:inline-flex;align-items:center;gap:10px;
      font-size:10px;font-weight:600;letter-spacing:0.22em;
      text-transform:uppercase;color:rgba(255,255,255,0.35);margin-bottom:56px;
    }
    .section-tag span{display:inline-block;width:32px;height:1px;background:linear-gradient(90deg,#7c3aed,#0ea5e9);}

    .about-grid{
      position:relative;z-index:2;
      display:grid;grid-template-columns:1fr 1fr;
      gap:70px;align-items:center;max-width:960px;margin:0 auto;
    }
    .img-col{
      position:relative;
      opacity:0;transform:translateX(-30px);
      transition:opacity 0.9s ease,transform 0.9s ease;
      perspective:900px;
    }
    .img-col.visible{opacity:1;transform:translateX(0);}
    .img-tilt{
      transform-style:preserve-3d;
      transition:transform 0.06s linear;
      border-radius:20px;will-change:transform;cursor:none;
    }
    .img-frame{position:relative;border-radius:20px;overflow:hidden;}
    .img-frame::before{
      content:'';position:absolute;inset:0;border-radius:20px;padding:2px;
      background:linear-gradient(135deg,#7c3aed,#4f46e5,#0ea5e9);
      -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;mask-composite:exclude;z-index:3;pointer-events:none;
    }
    .img-frame img{
      width:100%;aspect-ratio:4/5;object-fit:cover;object-position:center top;
      display:block;border-radius:20px;
      transition:filter 0.4s,transform 0.08s linear;
      filter:grayscale(20%);will-change:transform;
    }
    .img-tilt:hover .img-frame img{filter:grayscale(0%) brightness(1.04);}
    .shimmer{
      position:absolute;inset:0;border-radius:20px;z-index:4;pointer-events:none;
      background:radial-gradient(circle at 50% 50%,rgba(255,255,255,0.07) 0%,transparent 55%);
      opacity:0;transition:opacity 0.2s;
    }
    .img-tilt:hover .shimmer{opacity:1;}

    .float-badge{
      position:absolute;background:rgba(20,20,20,0.95);
      border:1px solid rgba(124,58,237,0.3);
      border-radius:14px;padding:14px 18px;z-index:10;
      box-shadow:0 8px 32px rgba(0,0,0,0.4);will-change:transform;
    }
    .exp-badge{bottom:-20px;right:-20px;}
    .tool-badge{top:20px;left:-20px;}
    .exp-num{
      font-family:'Anton',sans-serif;font-size:32px;line-height:1;letter-spacing:0.04em;
      background:linear-gradient(135deg,#7c3aed,#0ea5e9);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .badge-label{font-size:10px;font-weight:500;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.38);margin-top:4px;}
    .tool-dots{display:flex;gap:6px;align-items:center;margin-bottom:5px;}
    .td{width:9px;height:9px;border-radius:50%;}
    .td1{background:#9b59b6;}.td2{background:#3498db;}.td3{background:#e67e22;}

    .text-col{
      display:flex;flex-direction:column;gap:24px;
      opacity:0;transform:translateX(30px);
      transition:opacity 0.9s ease 0.2s,transform 0.9s ease 0.2s;
    }
    .text-col.visible{opacity:1;transform:translateX(0);}
    .about-heading{
      font-family:'Anton',sans-serif;font-size:clamp(40px,6vw,58px);
      color:#fff;letter-spacing:0.04em;line-height:1;
    }
    .about-heading span{
      background:linear-gradient(135deg,#7c3aed,#0ea5e9);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .divider{width:44px;height:2px;background:linear-gradient(90deg,#7c3aed,#0ea5e9);border-radius:2px;}
    .about-desc{font-size:14px;line-height:1.9;color:rgba(255,255,255,0.5);}
    .about-desc strong{color:rgba(255,255,255,0.88);font-weight:600;}
    .what-i-do{display:flex;flex-direction:column;gap:10px;}
    .do-item{
      display:flex;align-items:flex-start;gap:14px;
      padding:13px 16px;border-radius:12px;
      border:1px solid rgba(255,255,255,0.05);
      background:rgba(255,255,255,0.02);
      transition:background 0.25s,border-color 0.25s,transform 0.25s;cursor:default;
    }
    .do-item:hover{background:rgba(124,58,237,0.09);border-color:rgba(124,58,237,0.28);transform:translateX(8px);}
    .do-icon{width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0;}
    .di-1{background:rgba(124,58,237,0.15);}
    .di-2{background:rgba(14,165,233,0.15);}
    .di-3{background:rgba(16,185,129,0.15);}
    .do-title{font-size:13px;font-weight:700;color:#fff;letter-spacing:0.04em;}
    .do-sub{font-size:11px;color:rgba(255,255,255,0.33);margin-top:3px;}
    .open-line{
      font-size:11px;font-weight:500;letter-spacing:0.1em;text-transform:uppercase;
      color:rgba(255,255,255,0.32);border-left:2px solid #7c3aed;padding-left:14px;
      border-radius:0;
    }
    .cta-row{display:flex;gap:14px;}
    .btn-p{
      background:linear-gradient(135deg,#7c3aed,#4f46e5,#0ea5e9);color:#fff;border:none;
      padding:13px 28px;font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;
      border-radius:40px;cursor:pointer;font-family:'Inter',sans-serif;
      transition:opacity 0.2s,transform 0.15s;
    }
    .btn-p:hover{opacity:0.85;transform:scale(1.05);}
    .btn-o{
      background:transparent;color:rgba(255,255,255,0.6);
      border:1px solid rgba(255,255,255,0.15);
      padding:13px 28px;font-size:11px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;
      border-radius:40px;cursor:pointer;font-family:'Inter',sans-serif;
      transition:border-color 0.2s,color 0.2s,transform 0.15s;
    }
    .btn-o:hover{border-color:rgba(255,255,255,0.5);color:#fff;transform:scale(1.05);}

    /* ══════════════════════════════════════
       SKILLS SECTION
    ══════════════════════════════════════ */
    .skills{
      width:100%;
      background:#0a0a0a;
      background-image:
        radial-gradient(ellipse at 20% 50%, rgba(120,40,200,0.5) 0%, transparent 55%),
        radial-gradient(ellipse at 80% 50%, rgba(30,60,255,0.45) 0%, transparent 55%),
        radial-gradient(ellipse at 50% 100%, rgba(80,0,160,0.3) 0%, transparent 50%);
      position:relative;overflow:hidden;
      display:flex;flex-direction:column;align-items:center;
      padding:10px 40px 10px;
    }
    .skills::before{
      content:'';position:absolute;inset:0;z-index:0;opacity:0.03;
      background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      background-size:128px;pointer-events:none;
    }

    .heading-wrap{
      position:relative;z-index:5;
      text-align:left;width:100%;max-width:1100px;
      opacity:0;animation:skFadeUp 0.7s ease 0.1s forwards;
      margin-bottom:10px;
    }
    .skills-heading{
      font-family:'Anton',sans-serif;
      font-size:clamp(56px,9vw,100px);
      letter-spacing:0.04em;line-height:0.9;color:#fff;
    }
    .skills-heading{
      color:white;display:block;
    }

    /* STAGE — 3 column grid */
    .stage{
      position:relative;z-index:5;
      width:100%;max-width:1100px;
      display:grid;
      grid-template-columns:200px minmax(0,1fr) 200px;
      align-items:center;
      gap:0;
      min-height:500px;
    }

    /* LEFT SKILLS TEXT */
    .skills-left{
      display:flex;flex-direction:column;
      align-items:flex-end;
      padding-right:24px;gap:10px;
      opacity:0;animation:skSlideLeft 0.8s ease 0.8s forwards;
    }
    .craft-label{
      font-size:10px;font-weight:700;letter-spacing:0.22em;
      text-transform:uppercase;color:rgba(255,255,255,0.3);
    }
    .craft-title{
      font-family:'Anton',sans-serif;font-size:32px;
      letter-spacing:0.03em;line-height:1.05;text-align:right;
      background:linear-gradient(135deg,#c084fc,#818cf8);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .craft-desc{
      font-size:12px;line-height:1.7;
      color:rgba(255,255,255,0.38);
      text-align:right;max-width:160px;
    }
    .arrow-right{display:flex;align-items:center;margin-top:8px;}
    .arrow-line{flex:1;height:1.5px;background:linear-gradient(90deg,transparent,rgba(192,132,252,0.7));}
    .arrow-head{width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;border-left:9px solid rgba(192,132,252,0.7);}

    /* RIGHT SKILLS TEXT */
    .skills-right{
      display:flex;flex-direction:column;
      align-items:flex-start;
      padding-left:24px;gap:10px;
      opacity:0;animation:skSlideRight 0.8s ease 0.8s forwards;
    }
    .skills-right .craft-title{
      text-align:left;
      background:linear-gradient(135deg,#38bdf8,#6366f1);
      -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
    }
    .skills-right .craft-desc{text-align:left;}
    .arrow-left{display:flex;align-items:center;margin-top:8px;}
    .arrow-head-l{width:0;height:0;border-top:5px solid transparent;border-bottom:5px solid transparent;border-right:9px solid rgba(56,189,248,0.7);}
    .arrow-line-b{flex:1;height:1.5px;background:linear-gradient(90deg,rgba(56,189,248,0.7),transparent);}

    /* CHARACTER CENTER */
    .char-wrap{
      position:relative;
      display:flex;align-items:flex-end;justify-content:center;
      min-height:500px;
      opacity:0;animation:skCharIn 0.9s cubic-bezier(.22,1,.36,1) 0.4s forwards;
    }
    .char-wrap img.character{
      width:100%;max-width:460px;
      object-fit:contain;display:block;
      position:relative;z-index:5;
      filter:drop-shadow(0 0 60px rgba(124,58,237,0.4));
    }

    /* HAND IMAGES — raised above character's hands */
    .hand-img{
      position:absolute;z-index:8;
      border-radius:10px;overflow:hidden;
      box-shadow:0 12px 40px rgba(0,0,0,0.65);
    }
    .hand-img::before{
      content:'';position:absolute;inset:0;border-radius:10px;padding:1.5px;
      background:linear-gradient(135deg,#7c3aed,#0ea5e9);
      -webkit-mask:linear-gradient(#fff 0 0) content-box,linear-gradient(#fff 0 0);
      -webkit-mask-composite:xor;mask-composite:exclude;
      z-index:2;pointer-events:none;
    }
    .hand-img img{display:block;border-radius:10px;width:145px;}

    .img-graphic{
      bottom:38%;
      left:4%;
      animation:floatA 3.5s ease-in-out infinite;
      transform:rotate(-7deg);
    }
    .img-video{
      bottom:38%;
      right:4%;
      animation:floatB 3.5s ease-in-out infinite;
      transform:rotate(7deg);
    }

    .hand-glow{
      position:absolute;inset:-10px;border-radius:16px;
      background:radial-gradient(circle,rgba(124,58,237,0.28) 0%,transparent 70%);
      z-index:-1;animation:glowPulse 2.5s ease-in-out infinite;
    }
    .img-video .hand-glow{
      background:radial-gradient(circle,rgba(14,165,233,0.28) 0%,transparent 70%);
      animation-delay:0.7s;
    }

    /* TOOLS BAR */
    .tools-bar{
      position:relative;z-index:5;
      display:flex;justify-content:center;gap:14px;flex-wrap:wrap;
      margin-top:20px;
      opacity:0;animation:skFadeUp 0.7s ease 1.4s forwards;
    }
    .tool-pill{
      display:flex;align-items:center;gap:8px;
      padding:8px 16px;border-radius:40px;
      background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);
      transition:background 0.25s,border-color 0.25s,transform 0.2s;cursor:default;
    }
    .tool-pill:hover{background:rgba(124,58,237,0.12);border-color:rgba(124,58,237,0.3);transform:translateY(-3px);}
    .tdot{width:7px;height:7px;border-radius:50%;}
    .t1{background:#9b59b6;}.t2{background:#3498db;}.t3{background:#e67e22;}.t4{background:#e74c3c;}.t5{background:#1abc9c;}
    .tool-name{font-size:10px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:rgba(255,255,255,0.5);}

    /* SKILLS-ONLY KEYFRAMES (prefixed to avoid conflict) */
    @keyframes skFadeUp{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
    @keyframes skCharIn{from{opacity:0;transform:scale(0.92) translateY(16px);}to{opacity:1;transform:scale(1) translateY(0);}}
    @keyframes skSlideLeft{from{opacity:0;transform:translateX(-24px);}to{opacity:1;transform:translateX(0);}}
    @keyframes skSlideRight{from{opacity:0;transform:translateX(24px);}to{opacity:1;transform:translateX(0);}}
    @keyframes floatA{0%,100%{transform:rotate(-7deg) translateY(0);}50%{transform:rotate(-3deg) translateY(-12px);}}
    @keyframes floatB{0%,100%{transform:rotate(7deg) translateY(-6px);}50%{transform:rotate(3deg) translateY(6px);}}
    @keyframes glowPulse{0%,100%{opacity:0.5;}50%{opacity:1;}}

  </style>
</head>
<body>

  <!-- ══ HERO ══ -->
  <h2 style="position:absolute;width:1px;height:1px;overflow:hidden;clip:rect(0,0,0,0)">Hero section – Hi I'm Prashanth, Video Editor and Visual Designer</h2>

  <section class="hero">
    <div class="grain"></div>

    <nav class="nav" aria-label="Main navigation">
      <a>About</a>
      <a>Creations</a>
      <a>Projects</a>
      <a>Contact</a>
    </nav>

    <div class="hero-body">
      <div class="big-text" aria-label="Hi, I'm Prashanth">
        <span class="hi-line">HI, I'M</span>
        <span class="name-line">
          <span class="name-typed" id="nameTyped"></span>
          <span class="cursor-blink" id="nameCursor"></span>
        </span>
      </div>

      <div class="portrait">
        <img
          src="https://res.cloudinary.com/dm0ir0sw1/image/upload/v1780639541/ChatGPT_Image_Jun_5__2026__11_32_36_AM-removebg-preview_ejew5u.png"
          alt="Prashanth"/>
      </div>

      <div class="hero-left-text">
        <p>A video editor passionate<br>about crafting bold and<br>memorable projects.</p>
      </div>

      <div class="contact-btn">
        <button>Contact Me</button>
      </div>

      <div class="bottom-line"></div>
    </div>
  </section>

  <!-- ══ ABOUT ══ -->
  <div class="cursor-dot" id="cursorDot"></div>
  <div class="cursor-ring" id="cursorRing"></div>

  <section class="about" id="about">
